@using OpenFluency.Web.Models.Menu
@model OpenFluency.Web.Models.Menu.MenuViewModel

<nav class="navbar navbar-expand-md navbar-dark fixed-top bg-primary">
    <div class="container-fluid">
        <a class="navbar-brand" href="/">Open Fluency</a>
        <button class="navbar-toggler"
                type="button"
                data-bs-toggle="collapse"
                data-bs-target="#navbarCollapse"
                aria-controls="navbarCollapse"
                aria-expanded="false"
                aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarCollapse">
            <ul class="navbar-nav me-auto mb-2 mb-md-0">
                <li class="nav-item">
                    <a class="nav-link @(Model.Ativo == Menu.Home ? "active" : "")" aria-current="page" asp-controller="Home" asp-action="Index">Início</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(Model.Ativo == Menu.Aluno ? "active" : "")" asp-controller="Aluno" asp-action="Listar">Alunos</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(Model.Ativo == Menu.Professor ? "active" : "")" asp-controller="Professor" asp-action="Listar">Professores</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(Model.Ativo == Menu.Turma ? "active" : "")" asp-controller="Turma" asp-action="Listar">Turmas</a>
                </li>
            </ul>
            <form class="d-flex" role="search" asp-controller="Usuario" asp-action="Logout">
                <button class="btn btn-danger" type="submit">
                    Sair
                </button>
            </form>
        </div>
    </div>
</nav>